# Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL="postgresql://myuser:mypassword@localhost:5434/ndr_rescue?schema=public"

# Bolna AI
BOLNA_API_KEY="your-bolna-api-key-here"
BOLNA_AGENT_ID="your-agent-id-after-setup"

# App URL (use ngrok URL for local webhook testing, Vercel URL in production)
APP_URL="http://localhost:3000"

# Auth
JWT_SECRET="change-this-to-a-random-32-character-string"

# Webhook security
WEBHOOK_SECRET="my-super-secret-webhook-key"
